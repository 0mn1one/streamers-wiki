---
import { getCollection, render } from 'astro:content';
import WikiLayout from '../../layouts/WikiLayout.astro';
import Graph from '../../components/Graph.astro';
import { entryId } from '../../lib/links';

export async function getStaticPaths() {
  const entries = await getCollection('concepts');
  return entries.map((e) => ({ params: { slug: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const d = entry.data;

const infobox = [{ label: 'Category', value: d.category }];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: d.name,
  description: d.description,
  inDefinedTermSet: 'https://streamers.wiki/concepts/',
};
---
<WikiLayout type="concepts" slug={entry.id} title={d.name} description={d.description}
  updated={d.updated} tags={d.tags} sources={d.sources} infobox={infobox} jsonLd={jsonLd} headings={headings}>
  <Content />
  <section class="backlinks">
    <h3>Neighborhood</h3>
    <Graph focusId={entryId('concepts', entry.id)} height="420px" />
  </section>
</WikiLayout>
