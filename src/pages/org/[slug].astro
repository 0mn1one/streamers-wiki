---
import { getCollection, render } from 'astro:content';
import WikiLayout from '../../layouts/WikiLayout.astro';
import Graph from '../../components/Graph.astro';
import { entryId } from '../../lib/links';

export async function getStaticPaths() {
  const entries = await getCollection('orgs');
  return entries.map((e) => ({ params: { slug: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const d = entry.data;

const infobox = [
  { label: 'Founded', value: d.founded },
  { label: 'Founders', value: d.founders },
  { label: 'HQ', value: d.hq },
  { label: 'Type', value: d.type },
  { label: 'Members', value: d.members },
  { label: 'Website', value: d.url },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: d.name,
  description: d.description,
  url: d.url,
  foundingDate: d.founded,
};
---
<WikiLayout type="orgs" slug={entry.id} title={d.name} description={d.description}
  updated={d.updated} tags={d.tags} sources={d.sources} infobox={infobox} jsonLd={jsonLd} headings={headings}>
  <Content />
  <section class="backlinks">
    <h3>Neighborhood</h3>
    <Graph focusId={entryId('orgs', entry.id)} height="420px" />
  </section>
</WikiLayout>
