---
export interface Props {
  platform: 'twitch' | 'youtube';
  id: string;
  title?: string;
}
const { platform, id, title } = Astro.props as Props;

const twitchParent = 'streamers.wiki';
const src = platform === 'twitch'
  ? `https://clips.twitch.tv/embed?clip=${encodeURIComponent(id)}&parent=${twitchParent}&autoplay=false`
  : `https://www.youtube.com/embed/${encodeURIComponent(id)}`;
---
<figure class="clip">
  <div class="clip-frame">
    <iframe
      src={src}
      loading="lazy"
      allowfullscreen
      allow={platform === 'youtube' ? 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture' : 'autoplay; fullscreen'}
      title={title ?? 'Clip'}
    ></iframe>
  </div>
  {title && <figcaption class="clip-caption">{title}</figcaption>}
</figure>
<style>
  .clip { margin: 0; }
  .clip-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--bg-elev);
    border: 1px solid var(--border);
  }
  .clip-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .clip-caption { font-size: 0.85rem; color: var(--text-dim); margin-top: 0.4rem; }
</style>
