---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SearchOverlay from '../components/SearchOverlay.astro';

export interface Props {
  title: string;
  description: string;
  path?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  noMdTwin?: boolean;
  ogImage?: string;
}

const { title, description, path, jsonLd, noMdTwin, ogImage } = Astro.props as Props;
const site = 'https://streamers.wiki';
const url = new URL(Astro.url.pathname, site).toString();
const pathHasEntity = /^\/(streamer|platform|concept|event|org)\//.test(Astro.url.pathname);
const mdUrl = (!noMdTwin && pathHasEntity) ? url.replace(/\/$/, '') + '.md' : null;
const pageTitle = title === 'Streamers.wiki' ? title : `${title} — Streamers.wiki`;

const entityPathMatch = Astro.url.pathname.match(/^\/(streamer|platform|concept|event|org)\/([^/]+)\/?$/);
const typeMap: Record<string, string> = { streamer: 'streamers', platform: 'platforms', concept: 'concepts', event: 'events', org: 'orgs' };
const autoOg = entityPathMatch ? `/og/${typeMap[entityPathMatch[1]]}/${entityPathMatch[2]}.png` : '/og-default.png';
const og = ogImage ? new URL(ogImage, site).toString() : new URL(autoOg, site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#7c5cff" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0e0d15" />
    <meta name="msapplication-TileColor" content="#0e0d15" />
    <meta name="color-scheme" content="dark" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Streamers.wiki" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={og} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:image" content={og} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {mdUrl && <link rel="alternate" type="text/markdown" href={mdUrl} />}
    <link rel="alternate" type="application/rss+xml" title="Streamers.wiki" href="/rss.xml" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <SearchOverlay />
    <script>
      // Keyboard shortcut: / or Cmd+K to open search
      document.addEventListener('keydown', (e) => {
        const target = e.target as HTMLElement;
        const isTyping = target && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.isContentEditable);
        if (((e.key === 'k' || e.key === 'K') && (e.metaKey || e.ctrlKey)) || (e.key === '/' && !isTyping)) {
          e.preventDefault();
          window.dispatchEvent(new CustomEvent('swiki:search-open'));
        }
        if (e.key === 'Escape') {
          window.dispatchEvent(new CustomEvent('swiki:search-close'));
        }
      });
    </script>
  </body>
</html>
